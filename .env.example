# ─────────────────────────────────────────────────────────────────
# MindBodyRitual — Environment Variables
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to Git.
# ─────────────────────────────────────────────────────────────────

# ─── Supabase (database + waitlist) ──────────────────────────────
# Get these from: Supabase dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://[YOUR-PROJECT].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Brevo (email marketing) ─────────────────────────────────────
# Get this from: Brevo dashboard → Settings → API Keys → Create a new API key
# This is SERVER-SIDE ONLY — do NOT add NEXT_PUBLIC_ prefix.
BREVO_API_KEY=your-brevo-api-key-here

# Optional: The Brevo contact list ID to add waitlist signups to.
# Find it in Brevo → Contacts → Lists → click your list → the ID is in the URL.
# If omitted, contacts are added without a list assignment.
BREVO_LIST_ID=1

# ─── App ──────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://mindbodyritual.ca

# ─── Stripe (CAD) — add when payments are implemented ────────────
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
